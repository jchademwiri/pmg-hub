# Database - shared across all apps in the monorepo
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# Resend – TES sending identity
# Domain registered in Resend: tenderedgesolutions.co.za
# Central config: packages/emails/src/domains.ts → DOMAINS.tes
# resolveBrandEmailConfig('tes', import.meta.env) reads these keys
TES_RESEND_API_KEY=re_xxxxxxxxxxxx
TES_FROM_EMAIL=[EMAIL_ADDRESS]
TES_ADMIN_EMAIL=[EMAIL_ADDRESS]

# Site URL - used for canonical links and OG tags
TES_SITE_URL=https://www.tenderedgesolutions.co.za

# Cloudflare Turnstile (bot protection)
TURNSTILE_SITE_KEY=re_xxxxxxxxxxxx
TURNSTILE_SECRET_KEY=re_xxxxxxxxxxxx
