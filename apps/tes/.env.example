# ─────────────────────────────────────────────
# TES — Tender Edge Solutions
# apps/tes/.env.example
# Copy to .env.local and fill in real values.
# Never commit .env.local
#
# DATABASE_URL lives in the root .env.local —
# no need to repeat it here.
# ─────────────────────────────────────────────

# Resend — TES sending identity
# From domain: tenderedgesolutions.co.za (must be verified in Resend)
TES_RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
TES_FROM_EMAIL=noreply@tenderedgesolutions.co.za
TES_ADMIN_EMAIL=tenders@tenderedgesolutions.co.za

# Site
TES_SITE_URL=https://www.tenderedgesolutions.co.za
