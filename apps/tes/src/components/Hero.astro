---
// Hero.astro — Full-viewport opening section
---

<section
  id='hero'
  class='relative flex min-h-screen flex-col justify-center py-20 md:py-28 px-6 md:px-12 rounded-tr-3xl dot-grid'
>
  <div class='max-w-7xl mx-auto w-full grid md:grid-cols-2 gap-12 items-center'>
    <!-- Left: copy -->
    <div>
      <!-- Eyebrow -->
      <p
        class='eyebrow text-primary uppercase tracking-widest font-medium text-[10px] md:text-[11px]'
      >
        GAUTENG'S TENDER COMPLIANCE SPECIALISTS
      </p>

      <!-- H1 -->
      <h1
        class='hero-h1 font-condensed uppercase mt-4'
        style='font-size: clamp(56px, 10vw, 100px); line-height: 0.9; opacity: 0;'
      >
        WIN MORE <br />
        <span class='text-primary'>TENDERS.</span>
      </h1>

      <!-- Subheadline + CTAs wrapper -->
      <div class='sub-ctas mt-8 flex flex-col gap-6' style='opacity: 0;'>
        <p class='text-muted-foreground text-lg md:text-xl max-w-xl'>
          We handle your CSD registration, CIDB grading, B-BBEE affidavits, and full tender document
          compilation — so you can focus on winning.
        </p>

        <!-- CTA buttons -->
        <div class='flex flex-wrap items-center gap-4'>
          <a
            href="https://wa.me/27745017094?text=Hi%2C+I'm+interested+in+your+tender+compliance+services."
            target='_blank'
            rel='noopener noreferrer'
            class='inline-flex items-center gap-2 rounded-lg bg-whatsapp px-6 py-3 text-sm font-medium text-white transition-colors hover:bg-whatsapp-hover'
          >
            <svg
              xmlns='http://www.w3.org/2000/svg'
              width='20'
              height='20'
              viewBox='0 0 24 24'
              fill='currentColor'
              aria-hidden='true'
            >
              <path
                d='M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z'
              ></path>
            </svg>
            Get Your Free Assessment
          </a>
          <a
            href='#services'
            class='text-muted-foreground hover:text-foreground text-sm transition-colors'
          >
            View our services ↓
          </a>
        </div>

        <p class='text-muted-foreground text-sm'>
          Based in Centurion · Serving all of South Africa
        </p>
      </div>
    </div>

    <!-- Right: credential card panel (desktop only) -->
    <div class='hidden md:flex flex-col gap-4 relative'>
      <!-- Gold glow behind the cards -->
      <span
        aria-hidden='true'
        class='pointer-events-none absolute -top-16 -right-8 h-80 w-80 rounded-tr-2xl'
        style='background: radial-gradient(circle at top right, rgba(201,162,39,0.18), transparent 70%);'
      ></span>

      <!-- Stat cards -->
      <div class='grid grid-cols-2 gap-4 relative z-10'>
        <div
          class='bg-white/5 backdrop-blur-md border border-white/10 rounded-md p-5 flex flex-col gap-1'
        >
          <span class='text-primary font-condensed text-4xl font-bold leading-none'>CSD</span>
          <span class='text-foreground text-sm font-medium mt-1'>Registered Supplier</span>
          <span class='text-muted-foreground text-xs'>Central Supplier Database</span>
        </div>
        <div
          class='bg-white/5 backdrop-blur-md border border-white/10 rounded-md p-5 flex flex-col gap-1'
        >
          <span class='text-primary font-condensed text-4xl font-bold leading-none'>CIDB</span>
          <span class='text-foreground text-sm font-medium mt-1'>Grading Specialists</span>
          <span class='text-muted-foreground text-xs'>All contractor grades</span>
        </div>
        <div
          class='bg-white/5 backdrop-blur-md border border-white/10 rounded-md p-5 flex flex-col gap-1'
        >
          <span class='text-primary font-condensed text-4xl font-bold leading-none'>B-BBEE</span>
          <span class='text-foreground text-sm font-medium mt-1'>Affidavit Experts</span>
          <span class='text-muted-foreground text-xs'>EME & QSE compliant</span>
        </div>
        <div
          class='bg-white/5 backdrop-blur-md border border-white/10 rounded-md p-5 flex flex-col gap-1'
        >
          <span class='text-primary font-condensed text-4xl font-bold leading-none'>24h</span>
          <span class='text-foreground text-sm font-medium mt-1'>Fast Turnaround</span>
          <span class='text-muted-foreground text-xs'>Deadline-driven service</span>
        </div>
      </div>

      <!-- Free assessment callout -->
      <div
        class='bg-primary/10 backdrop-blur-md border border-primary/30 rounded-md p-5 relative z-10'
      >
        <p class='text-primary font-semibold text-sm'>Free Tender Readiness Assessment</p>
        <p class='text-muted-foreground text-xs mt-1'>
          No commitment required. We'll tell you exactly what you need.
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .eyebrow {
    animation: fadeUp 0.6s ease forwards;
    animation-delay: 0ms;
  }

  .hero-h1 {
    animation: fadeUp 0.6s ease forwards;
    animation-delay: 100ms;
    opacity: 0;
  }

  .sub-ctas {
    animation: fadeUp 0.6s ease forwards;
    animation-delay: 250ms;
    opacity: 0;
  }
</style>
