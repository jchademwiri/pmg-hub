---
// Hero.astro - Full-viewport opening section with mobile stat cards
---

<section
  id='hero'
  class='relative flex min-h-screen flex-col justify-center py-20 md:py-28 px-6 md:px-12 rounded-tr-3xl dot-grid'
>
  <div class='max-w-7xl mx-auto w-full grid md:grid-cols-2 gap-12 items-center'>
    <!-- Left: copy -->
    <div>
      <p
        class='hero-eyebrow text-primary uppercase tracking-widest font-medium text-[10px] md:text-[11px]'
      >
        GAUTENG'S TENDER COMPLIANCE SPECIALISTS
      </p>

      <h1
        class='hero-heading font-condensed uppercase mt-4'
        style='font-size: clamp(56px, 10vw, 100px); line-height: 0.9;'
      >
        WIN MORE <br />
        <span class='text-primary'>TENDERS.</span>
      </h1>

      <div class='hero-body mt-8 flex flex-col gap-6'>
        <p class='text-muted-foreground text-lg md:text-xl max-w-xl'>
          We handle your CSD registration, CIDB grading, B-BBEE affidavits, and full tender document
          compilation - so you can focus on winning.
        </p>

        <div class='flex flex-wrap items-center gap-4'>
          <a
            href="https://wa.me/27745017094?text=Hi%2C+I'm+interested+in+your+tender+compliance+services."
            target='_blank'
            rel='noopener noreferrer'
            class='inline-flex items-center gap-2 rounded-lg bg-whatsapp px-6 py-3 text-sm font-medium text-white transition-all duration-200 hover:bg-whatsapp-hover hover:-translate-y-px active:scale-[0.97]'
          >
            <svg
              xmlns='http://www.w3.org/2000/svg'
              width='20'
              height='20'
              viewBox='0 0 24 24'
              fill='currentColor'
              aria-hidden='true'
            >
              <path
                d='M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z'
              ></path>
            </svg>
            Get Your Free Assessment
          </a>

          <a
            href='#services'
            class='group inline-flex items-center gap-1.5 text-muted-foreground hover:text-foreground text-sm transition-colors'
            aria-label='Skip to services section'
          >
            View our services
            <svg
              xmlns='http://www.w3.org/2000/svg'
              width='14'
              height='14'
              viewBox='0 0 24 24'
              fill='none'
              stroke='currentColor'
              stroke-width='2'
              stroke-linecap='round'
              stroke-linejoin='round'
              aria-hidden='true'
              class='transition-transform duration-200 group-hover:translate-y-0.5'
            >
              <line x1='12' y1='5' x2='12' y2='19'></line>
              <polyline points='19 12 12 19 5 12'></polyline>
            </svg>
          </a>
        </div>

        <p class='text-muted-foreground text-sm'>
          Based in Centurion · Serving all of South Africa
        </p>
      </div>

      <!-- Mobile stat cards -->
      <div class='hero-stat-cards md:hidden grid grid-cols-2 gap-3 mt-8'>
        {
          [
            { label: 'CSD', sub: 'Registered Supplier', detail: 'Central Supplier Database' },
            { label: 'CIDB', sub: 'Grading Specialists', detail: 'All contractor grades' },
            { label: 'B-BBEE', sub: 'Affidavit Experts', detail: 'EME & QSE compliant' },
            { label: '24h', sub: 'Fast Turnaround', detail: 'Deadline-driven service' },
          ].map((card) => (
            <div class='bg-white/5 border border-white/10 rounded-md p-4 flex flex-col gap-1'>
              <span class='text-primary font-condensed text-3xl font-bold leading-none'>
                {card.label}
              </span>
              <span class='text-foreground text-xs font-medium mt-1'>{card.sub}</span>
              <span class='text-muted-foreground text-[11px]'>{card.detail}</span>
            </div>
          ))
        }
      </div>
    </div>

    <!-- Right: credential card panel (desktop only) -->
    <div class='hidden md:flex flex-col gap-4 relative'>
      <span
        aria-hidden='true'
        class='pointer-events-none absolute -top-16 -right-8 h-80 w-80 rounded-tr-2xl'
        style='background: radial-gradient(circle at top right, rgba(201,162,39,0.18), transparent 70%);'
      ></span>

      <div class='grid grid-cols-2 gap-4 relative z-10'>
        {
          [
            { label: 'CSD', sub: 'Registered Supplier', detail: 'Central Supplier Database' },
            { label: 'CIDB', sub: 'Grading Specialists', detail: 'All contractor grades' },
            { label: 'B-BBEE', sub: 'Affidavit Experts', detail: 'EME & QSE compliant' },
            { label: '24h', sub: 'Fast Turnaround', detail: 'Deadline-driven service' },
          ].map((card) => (
            <div class='bg-white/5 backdrop-blur-md border border-white/10 rounded-md p-5 flex flex-col gap-1'>
              <span class='text-primary font-condensed text-4xl font-bold leading-none'>
                {card.label}
              </span>
              <span class='text-foreground text-sm font-medium mt-1'>{card.sub}</span>
              <span class='text-muted-foreground text-xs'>{card.detail}</span>
            </div>
          ))
        }
      </div>

      <div
        class='bg-primary/10 backdrop-blur-md border border-primary/30 rounded-md p-5 relative z-10'
      >
        <p class='text-primary font-semibold text-sm'>Free Tender Readiness Assessment</p>
        <p class='text-muted-foreground text-xs mt-1'>
          No commitment required. We'll tell you exactly what you need.
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero-eyebrow {
    opacity: 0;
    animation: fadeUp 0.6s ease forwards 0ms;
  }
  .hero-heading {
    opacity: 0;
    animation: fadeUp 0.6s ease forwards 100ms;
  }
  .hero-body {
    opacity: 0;
    animation: fadeUp 0.6s ease forwards 250ms;
  }
  .hero-stat-cards {
    opacity: 0;
    animation: fadeUp 0.6s ease forwards 250ms;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-eyebrow,
    .hero-heading,
    .hero-body,
    .hero-stat-cards {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }
</style>
