---
// HowItWorks.astro — Three-step process section
---

<section id='process' class='bg-background py-20 md:py-28 px-6 md:px-12'>
  <div class='max-w-7xl mx-auto'>
    <!-- Eyebrow -->
    <p class='text-primary uppercase tracking-widest text-[10px] md:text-[11px] font-medium'>
      THE PROCESS
    </p>

    <!-- Heading -->
    <h2 class='font-condensed text-4xl md:text-5xl text-foreground mt-4 mb-12'>
      Simple. Fast. Submission-ready.
    </h2>

    <!-- Desktop: horizontal steps with connecting line -->
    <div class='hidden md:flex items-start gap-0 relative mt-12'>
      <!-- Dashed connecting line -->
      <div
        class='absolute top-9 left-[calc(16.666%+1rem)] right-[calc(16.666%+1rem)] border-t border-dashed border-primary/40'
        aria-hidden='true'
      >
      </div>

      <!-- Step 1 -->
      <div class='flex-1 px-8 relative z-10'>
        <span class='text-primary font-condensed text-7xl leading-none'>01</span>
        <h3 class='text-foreground font-semibold text-lg mt-2'>Send Your Documents</h3>
        <p class='text-muted-foreground text-sm leading-relaxed mt-2'>
          WhatsApp or email us your existing documents. We'll review everything within 24 hours and
          tell you exactly what's needed.
        </p>
      </div>

      <!-- Step 2 -->
      <div class='flex-1 px-8 relative z-10'>
        <span class='text-primary font-condensed text-7xl leading-none'>02</span>
        <h3 class='text-foreground font-semibold text-lg mt-2'>We Handle Everything</h3>
        <p class='text-muted-foreground text-sm leading-relaxed mt-2'>
          We process your registrations, complete all required forms, and compile your full tender
          submission package.
        </p>
      </div>

      <!-- Step 3 -->
      <div class='flex-1 px-8 relative z-10'>
        <span class='text-primary font-condensed text-7xl leading-none'>03</span>
        <h3 class='text-foreground font-semibold text-lg mt-2'>You Submit With Confidence</h3>
        <p class='text-muted-foreground text-sm leading-relaxed mt-2'>
          Receive your complete, professionally packaged submission — ready to hand in before the
          deadline.
        </p>
      </div>
    </div>

    <!-- Mobile: vertical timeline -->
    <div class='flex md:hidden flex-col gap-8 mt-12'>
      <!-- Step 1 -->
      <div>
        <span class='text-primary font-condensed text-7xl leading-none'>01</span>
        <h3 class='text-foreground font-semibold text-lg mt-2'>Send Your Documents</h3>
        <p class='text-muted-foreground text-sm leading-relaxed mt-2'>
          WhatsApp or email us your existing documents. We'll review everything within 24 hours and
          tell you exactly what's needed.
        </p>
      </div>

      <!-- Step 2 -->
      <div>
        <span class='text-primary font-condensed text-7xl leading-none'>02</span>
        <h3 class='text-foreground font-semibold text-lg mt-2'>We Handle Everything</h3>
        <p class='text-muted-foreground text-sm leading-relaxed mt-2'>
          We process your registrations, complete all required forms, and compile your full tender
          submission package.
        </p>
      </div>

      <!-- Step 3 -->
      <div>
        <span class='text-primary font-condensed text-7xl leading-none'>03</span>
        <h3 class='text-foreground font-semibold text-lg mt-2'>You Submit With Confidence</h3>
        <p class='text-muted-foreground text-sm leading-relaxed mt-2'>
          Receive your complete, professionally packaged submission — ready to hand in before the
          deadline.
        </p>
      </div>
    </div>

    <!-- Bottom WhatsApp CTA -->
    <div class='mt-12 flex justify-center'>
      <a
        href="https://wa.me/27745017094?text=Hi%2C+I'm+interested+in+your+tender+compliance+services."
        target='_blank'
        rel='noopener noreferrer'
        class='bg-whatsapp hover:bg-whatsapp-hover text-white inline-flex items-center gap-2 px-6 py-3 rounded-lg text-sm font-medium transition-colors'
      >
        <!-- WhatsApp SVG icon -->
        <svg
          xmlns='http://www.w3.org/2000/svg'
          width='18'
          height='18'
          viewBox='0 0 24 24'
          fill='currentColor'
          aria-hidden='true'
        >
          <path
            d='M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z'
          ></path>
        </svg>
        Start the Process on WhatsApp
      </a>
    </div>
  </div>
</section>
