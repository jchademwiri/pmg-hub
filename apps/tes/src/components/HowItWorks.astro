---
// HowItWorks.astro — Three-step process section
---

<section id='process' class='bg-background py-20 md:py-28 px-6 md:px-12 diagonal-lines'>
  <div class='max-w-7xl mx-auto'>
    <p class='reveal text-primary uppercase tracking-widest text-[10px] md:text-[11px] font-medium'>
      THE PROCESS
    </p>
    <h2 class='reveal font-condensed text-4xl md:text-5xl text-foreground mt-4 mb-14' data-delay="80">
      Simple. Fast. Submission-ready.
    </h2>

    <!-- Desktop: horizontal steps with connector arrows -->
    <div class='hidden md:grid items-start' style='grid-template-columns: 1fr 48px 1fr 48px 1fr;'>

      <!-- Step 1 -->
      <div class='reveal flex flex-col gap-3' data-delay="0">
        <div class='flex items-center gap-3'>
          <div class='step-num w-11 h-11 rounded-full border border-primary/60 flex items-center justify-center shrink-0'>
            <span class='text-primary font-condensed text-base font-semibold tracking-wide'>01</span>
          </div>
          <h3 class='text-foreground font-semibold text-base'>Send Your Documents</h3>
        </div>
        <p class='text-muted-foreground text-sm leading-relaxed' style='padding-left: 56px;'>
          WhatsApp or email us your existing documents. We'll review everything within 24 hours and tell you exactly what's needed.
        </p>
      </div>

      <!-- Connector 1→2 -->
      <div class='flex items-center justify-center' style='padding-top: 22px;'>
        <div class='connector-arrow w-full'></div>
      </div>

      <!-- Step 2 -->
      <div class='reveal flex flex-col gap-3' data-delay="100">
        <div class='flex items-center gap-3'>
          <div class='step-num w-11 h-11 rounded-full border border-primary/60 flex items-center justify-center shrink-0'>
            <span class='text-primary font-condensed text-base font-semibold tracking-wide'>02</span>
          </div>
          <h3 class='text-foreground font-semibold text-base'>We Handle Everything</h3>
        </div>
        <p class='text-muted-foreground text-sm leading-relaxed' style='padding-left: 56px;'>
          We process your registrations, complete all required forms, and compile your full tender submission package.
        </p>
      </div>

      <!-- Connector 2→3 -->
      <div class='flex items-center justify-center' style='padding-top: 22px;'>
        <div class='connector-arrow w-full'></div>
      </div>

      <!-- Step 3 -->
      <div class='reveal flex flex-col gap-3' data-delay="200">
        <div class='flex items-center gap-3'>
          <div class='step-num w-11 h-11 rounded-full border border-primary/60 flex items-center justify-center shrink-0'>
            <span class='text-primary font-condensed text-base font-semibold tracking-wide'>03</span>
          </div>
          <h3 class='text-foreground font-semibold text-base'>You Submit With Confidence</h3>
        </div>
        <p class='text-muted-foreground text-sm leading-relaxed' style='padding-left: 56px;'>
          Receive your complete, professionally packaged submission — ready to hand in before the deadline.
        </p>
      </div>
    </div>

    <!-- Mobile: vertical timeline -->
    <div class='flex md:hidden flex-col gap-0'>
      {[
        { n: '01', title: 'Send Your Documents', desc: "WhatsApp or email us your existing documents. We'll review everything within 24 hours and tell you exactly what's needed." },
        { n: '02', title: 'We Handle Everything', desc: 'We process your registrations, complete all required forms, and compile your full tender submission package.' },
        { n: '03', title: 'You Submit With Confidence', desc: 'Receive your complete, professionally packaged submission — ready to hand in before the deadline.' },
      ].map((step, i) => (
        <div class='flex gap-4'>
          <!-- Left: number + vertical line -->
          <div class='flex flex-col items-center'>
            <div class='step-num w-11 h-11 rounded-full border border-primary/60 flex items-center justify-center shrink-0'>
              <span class='text-primary font-condensed text-base font-semibold tracking-wide'>{step.n}</span>
            </div>
            {i < 2 && <div class='w-px flex-1 my-2' style='background: rgba(201,162,39,0.25); min-height: 32px;'></div>}
          </div>
          <!-- Right: content -->
          <div class='pb-8 pt-2'>
            <h3 class='text-foreground font-semibold text-base mb-2'>{step.title}</h3>
            <p class='text-muted-foreground text-sm leading-relaxed'>{step.desc}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class='reveal mt-14 flex justify-center' data-delay="200">
      <a
        href="https://wa.me/27745017094?text=Hi%2C+I'm+interested+in+your+tender+compliance+services."
        target='_blank'
        rel='noopener noreferrer'
        class='bg-whatsapp hover:bg-whatsapp-hover text-white inline-flex items-center gap-2 px-6 py-3 rounded-lg text-sm font-medium transition-all duration-200 hover:-translate-y-px active:scale-[0.97]'
      >
        <svg xmlns='http://www.w3.org/2000/svg' width='18' height='18' viewBox='0 0 24 24' fill='currentColor' aria-hidden='true'>
          <path d='M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z'></path>
        </svg>
        Start the Process on WhatsApp
      </a>
    </div>
  </div>
</section>

<style>
  .connector-arrow {
    height: 1px;
    background: rgba(201, 162, 39, 0.25);
    position: relative;
  }
  .connector-arrow::after {
    content: '';
    position: absolute;
    right: -1px;
    top: -4px;
    width: 7px;
    height: 7px;
    border-top: 1.5px solid rgba(201, 162, 39, 0.45);
    border-right: 1.5px solid rgba(201, 162, 39, 0.45);
    transform: rotate(45deg);
  }
  .step-num {
    transition: border-color 0.2s ease, background-color 0.2s ease;
  }
  .step-num:hover {
    background-color: rgba(201, 162, 39, 0.08);
    border-color: rgba(201, 162, 39, 1);
  }
</style>