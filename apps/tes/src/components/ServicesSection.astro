---
import { services } from '../data/services';

const icons = [
  // CSD Registration — document
  `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#c9a227" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>`,
  // CIDB Grading — badge/medal
  `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#c9a227" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89L17 22l-5-3-5 3 1.523-9.11"/></svg>`,
  // B-BBEE — shield
  `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#c9a227" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
  // COIDA — checkmark circle
  `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#c9a227" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>`,
  // SBD Forms — edit/pen
  `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#c9a227" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>`,
  // Full Tender — folder
  `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#c9a227" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>`,
];
---

<section id='services' class='bg-card py-20 md:py-28 px-6 md:px-12 dot-grid'>
  <div class='max-w-7xl mx-auto'>
    <p class='reveal text-primary uppercase tracking-widest text-[10px] md:text-[11px] font-medium'>
      WHAT WE DO
    </p>
    <h2 class='reveal font-condensed text-4xl md:text-5xl text-foreground mt-4 mb-12' data-delay="80">
      Everything you need to submit with confidence.
    </h2>

    <div class='grid grid-cols-1 md:grid-cols-2 gap-4'>
      {services.map((service, i) => (
        <div class='reveal service-card bg-background border border-[--border] rounded-xl p-5 flex flex-col gap-3 relative overflow-hidden' data-delay={String((i % 2) * 80)}>
          <!-- Gold left accent bar -->
          <span class='accent-bar' aria-hidden='true'></span>

          <!-- Icon + title row -->
          <div class='flex items-start gap-3'>
            <div class='icon-wrap shrink-0 w-9 h-9 rounded-lg flex items-center justify-center' style='background: rgba(201,162,39,0.12);'>
              <Fragment set:html={icons[i]} />
            </div>
            <p class='text-foreground font-semibold text-base pt-1'>{service.name}</p>
          </div>

          <p class='text-muted-foreground text-sm leading-relaxed'>{service.description}</p>
        </div>
      ))}
    </div>

    <!-- Bundle teaser -->
    <div class='reveal mt-4 bg-primary/10 border border-primary/30 rounded-xl p-5 flex flex-col md:flex-row items-start md:items-center justify-between gap-4' data-delay="160">
      <div>
        <p class='text-foreground font-semibold'>Tender-Ready Bundles</p>
        <p class='text-muted-foreground text-sm'>
          We offer all-inclusive compliance packages — everything you need in one engagement. Get in touch for a quote.
        </p>
      </div>
      <a
        href='#contact'
        class='text-primary hover:text-primary-hover font-medium text-sm transition-colors whitespace-nowrap flex items-center gap-1.5'
      >
        Get a quote
        <svg xmlns='http://www.w3.org/2000/svg' width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true'><line x1='5' y1='12' x2='19' y2='12'/><polyline points='12 5 19 12 12 19'/></svg>
      </a>
    </div>
  </div>
</section>

<style>
  .service-card {
    transition: border-color 0.2s ease, background-color 0.2s ease;
  }
  .service-card:hover {
    border-color: rgba(201, 162, 39, 0.4);
    background-color: rgba(201, 162, 39, 0.03);
  }
  .accent-bar {
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: var(--primary);
    border-radius: 3px 0 0 3px;
    transform: scaleY(0);
    transform-origin: bottom;
    transition: transform 0.25s ease;
  }
  .service-card:hover .accent-bar {
    transform: scaleY(1);
  }
</style>