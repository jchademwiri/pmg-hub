---
const items = [
  {
    label: 'CSD',
    sublabel: 'Registered Supplier',
    icon: `<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>`,
  },
  {
    label: 'CIDB',
    sublabel: 'Grading Specialists',
    icon: `<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89L17 22l-5-3-5 3 1.523-9.11"/></svg>`,
  },
  {
    label: 'B-BBEE',
    sublabel: 'Affidavit Experts',
    icon: `<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
  },
  {
    label: 'Centurion-Based',
    sublabel: 'Serving Gauteng',
    icon: `<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>`,
  },
  {
    label: '24h Turnaround',
    sublabel: 'Deadline-Driven',
    icon: `<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
  },
];
---

<section class='bg-card border-y border-[--border] py-5 px-6 lg:px-12' aria-label='Trust signals'>
  <ul
    class='grid grid-cols-1 sm:grid-cols-2 lg:flex lg:items-center lg:justify-center list-none m-0 p-0 gap-y-3 sm:gap-y-4 lg:gap-0'
    role='list'
  >
    {
      items.map((item, i) => (
        <li
          class={`flex items-center gap-3 px-4 py-2 rounded-lg bg-[--bg-secondary] lg:bg-transparent lg:px-5 lg:py-0 sm:border-t sm:border-[--border] ${i >= 1 ? 'lg:border-l lg:border-t-0' : ''}`}
        >
          <span class='text-primary shrink-0'>
            <Fragment set:html={item.icon} />
          </span>
          <span class='text-sm'>
            <span class='text-foreground font-medium'>{item.label}</span>
            <span class='text-muted-foreground hidden sm:inline'> · {item.sublabel}</span>
            <span class='text-muted-foreground sm:hidden block'>{item.sublabel}</span>
          </span>
        </li>
      ))
    }
  </ul>
</section>
