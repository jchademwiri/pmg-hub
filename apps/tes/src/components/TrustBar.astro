---
const pills = [
  'CSD Registered Supplier',
  'CIDB Grading Specialists',
  'B-BBEE Affidavit Experts',
  'Centurion-Based · Serving Gauteng',
  'Fast Turnaround · Deadline-Driven',
];
---

<section class='bg-card py-6 px-6 md:px-12'>
  <div class='overflow-x-auto scrollbar-hide'>
    <div class='flex gap-3 md:gap-4 md:justify-center'>
      {
        pills.map((label) => (
          <div class='border border-[--border] rounded-full px-4 py-2 flex items-center gap-2 whitespace-nowrap'>
            <svg
              xmlns='http://www.w3.org/2000/svg'
              width='14'
              height='14'
              viewBox='0 0 24 24'
              fill='none'
              stroke='currentColor'
              stroke-width='2.5'
              stroke-linecap='round'
              stroke-linejoin='round'
              class='text-primary shrink-0'
              aria-hidden='true'
            >
              <polyline points='20 6 9 17 4 12' />
            </svg>
            <span class='text-muted-foreground text-sm'>{label}</span>
          </div>
        ))
      }
    </div>
  </div>
</section>
