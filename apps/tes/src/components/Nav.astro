---
// Nav.astro — Fixed top navigation for TenderEdge Solutions
---

<nav
  id='site-nav'
  class='fixed top-0 left-0 right-0 w-full z-50 transition-all duration-300 px-6 md:px-12 py-4'
  aria-label='Main navigation'
>
  <div class='max-w-7xl mx-auto flex items-center justify-between'>
    <!-- Left: TES Wordmark -->
    <a
      href='/'
      class='font-condensed font-bold text-xl leading-none shrink-0'
      aria-label='TenderEdge Solutions — home'
    >
      <span class='text-foreground'>TenderEdge</span><span class='text-primary'>Solutions</span>
    </a>

    <!-- Centre: Desktop anchor links -->
    <ul class='hidden md:flex gap-6 list-none m-0 p-0' role='list'>
      <li>
        <a
          href='#services'
          class='text-muted-foreground hover:text-foreground text-sm transition-colors'>Services</a
        >
      </li>
      <li>
        <a
          href='#process'
          class='text-muted-foreground hover:text-foreground text-sm transition-colors'>Process</a
        >
      </li>
      <li>
        <a
          href='#pricing'
          class='text-muted-foreground hover:text-foreground text-sm transition-colors'>Packages</a
        >
      </li>
      <li>
        <a
          href='#results'
          class='text-muted-foreground hover:text-foreground text-sm transition-colors'>Results</a
        >
      </li>
      <li>
        <a
          href='#contact'
          class='text-muted-foreground hover:text-foreground text-sm transition-colors'>Contact</a
        >
      </li>
    </ul>

    <!-- Right: WhatsApp CTA + Mobile hamburger -->
    <div class='flex items-center gap-3'>
      <!-- WhatsApp CTA button -->
      <a
        href="https://wa.me/27745017094?text=Hi%2C+I'm+interested+in+your+tender+compliance+services."
        target='_blank'
        rel='noopener noreferrer'
        class='inline-flex items-center gap-2 bg-whatsapp hover:bg-whatsapp-hover text-white text-sm font-medium px-4 py-2 rounded-lg transition-colors shrink-0'
        aria-label='Contact us on WhatsApp'
      >
        <svg
          xmlns='http://www.w3.org/2000/svg'
          width='16'
          height='16'
          viewBox='0 0 24 24'
          fill='currentColor'
          aria-hidden='true'
        >
          <path
            d='M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z'
          ></path>
        </svg>
        <span class='hidden sm:inline'>WhatsApp Us</span>
      </a>

      <!-- Mobile hamburger toggle -->
      <button
        id='mobile-menu-toggle'
        class='md:hidden flex flex-col justify-center items-center w-9 h-9 gap-1.5 rounded-md text-foreground hover:text-primary transition-colors'
        aria-expanded='false'
        aria-controls='mobile-menu'
        aria-label='Toggle navigation menu'
      >
        <span class='hamburger-bar block w-5 h-0.5 bg-current transition-all duration-300'></span>
        <span class='hamburger-bar block w-5 h-0.5 bg-current transition-all duration-300'></span>
        <span class='hamburger-bar block w-5 h-0.5 bg-current transition-all duration-300'></span>
      </button>
    </div>
  </div>

  <!-- Mobile slide-down menu -->
  <div
    id='mobile-menu'
    class='fixed top-0 left-0 right-0 z-40 pt-20 px-6 pb-6 bg-background/95 backdrop-blur-md border-b border-border transform -translate-y-full transition-transform duration-300 md:hidden'
    aria-hidden='true'
  >
    <ul class='flex flex-col gap-1 list-none m-0 p-0' role='list'>
      <li>
        <a
          href='#services'
          class='mobile-nav-link block py-3 text-muted-foreground hover:text-foreground text-base transition-colors border-b border-border/50'
          >Services</a
        >
      </li>
      <li>
        <a
          href='#process'
          class='mobile-nav-link block py-3 text-muted-foreground hover:text-foreground text-base transition-colors border-b border-border/50'
          >Process</a
        >
      </li>
      <li>
        <a
          href='#pricing'
          class='mobile-nav-link block py-3 text-muted-foreground hover:text-foreground text-base transition-colors border-b border-border/50'
          >Packages</a
        >
      </li>
      <li>
        <a
          href='#results'
          class='mobile-nav-link block py-3 text-muted-foreground hover:text-foreground text-base transition-colors border-b border-border/50'
          >Results</a
        >
      </li>
      <li>
        <a
          href='#contact'
          class='mobile-nav-link block py-3 text-muted-foreground hover:text-foreground text-base transition-colors'
          >Contact</a
        >
      </li>
    </ul>
  </div>

  <script>
    const nav = document.getElementById('site-nav') as HTMLElement;
    const toggle = document.getElementById('mobile-menu-toggle') as HTMLButtonElement;
    const mobileMenu = document.getElementById('mobile-menu') as HTMLElement;
    let menuOpen = false;

    // Scroll-based nav background
    function updateNavBackground() {
      if (window.scrollY > 40) {
        nav.classList.add('bg-background/90', 'backdrop-blur-md');
      } else {
        nav.classList.remove('bg-background/90', 'backdrop-blur-md');
      }
    }

    window.addEventListener('scroll', updateNavBackground, { passive: true });
    updateNavBackground();

    // Mobile menu toggle
    function openMenu() {
      menuOpen = true;
      mobileMenu.classList.remove('-translate-y-full');
      mobileMenu.setAttribute('aria-hidden', 'false');
      toggle.setAttribute('aria-expanded', 'true');
      // Animate hamburger to X
      const bars = toggle.querySelectorAll('.hamburger-bar');
      bars[0]?.classList.add('rotate-45', 'translate-y-2');
      bars[1]?.classList.add('opacity-0');
      bars[2]?.classList.add('-rotate-45', '-translate-y-2');
    }

    function closeMenu() {
      menuOpen = false;
      mobileMenu.classList.add('-translate-y-full');
      mobileMenu.setAttribute('aria-hidden', 'true');
      toggle.setAttribute('aria-expanded', 'false');
      // Restore hamburger
      const bars = toggle.querySelectorAll('.hamburger-bar');
      bars[0]?.classList.remove('rotate-45', 'translate-y-2');
      bars[1]?.classList.remove('opacity-0');
      bars[2]?.classList.remove('-rotate-45', '-translate-y-2');
    }

    toggle.addEventListener('click', () => {
      menuOpen ? closeMenu() : openMenu();
    });

    // Close menu when a mobile nav link is clicked
    mobileMenu.querySelectorAll('.mobile-nav-link').forEach((link) => {
      link.addEventListener('click', closeMenu);
    });
  </script>
</nav>
