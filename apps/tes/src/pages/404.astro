---
export const prerender = false;
import Layout from '@/layouts/Layout.astro';
---

<Layout title='404 - Page Not Found | Tender Edge Solutions'>
  <div class='error-content'>
    <h1 class='text-9xl font-bold text-gold'>404</h1>
    <p class='text-2xl font-semibold mb-4'>It looks like you are lost</p>
    <p class='text-muted mb-8'>The page you're looking for doesn't exist or has been moved.</p>
    <a href='/' class='btn-gold'> Return Home </a>
  </div>
</Layout>

<style>
  .error-content {
    min-height: 80vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: 4rem 1rem;
  }
  .text-gold {
    color: #c9a227;
  }
  .text-muted {
    color: #9ca3af;
  }
  .bg-gold {
    background: #c9a227;
  }
  .text-black {
    color: #000;
  }
  .text-9xl {
    font-size: 8rem;
  }
  .text-2xl {
    font-size: 1.5rem;
  }
  .font-bold {
    font-weight: 700;
  }
  .font-semibold {
    font-weight: 600;
  }
  .mb-4 {
    margin-bottom: 1rem;
  }
  .mb-8 {
    margin-bottom: 2rem;
  }
  .px-6 {
    padding-left: 1.5rem;
    padding-right: 1.5rem;
  }
  .py-3 {
    padding-top: 0.75rem;
    padding-bottom: 0.75rem;
  }
  .rounded-lg {
    border-radius: 0.5rem;
  }
  .hover\:bg-gold\/90:hover {
    background: #b8922a;
  }
  .transition-colors {
    transition: background 0.2s;
  }
  .btn-gold {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    background: #c9a227;
    color: #000;
    font-weight: 600;
    border-radius: 0.5rem;
    transition: background 0.2s;
    text-decoration: none;
  }
  .btn-gold:hover {
    background: #b8922a;
  }
</style>
