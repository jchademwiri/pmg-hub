# ─────────────────────────────────────────────
# PMG — Playhouse Media Group
# apps/pmg/.env.example
# Copy to .env.local and fill in real values.
# Never commit .env.local
#
# DATABASE_URL lives in the root .env.local —
# no need to repeat it here.
# ─────────────────────────────────────────────

# Resend — PMG sending identity
# From domain: playhousemedia.co.za (must be verified in Resend)
PMG_RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
PMG_FROM_EMAIL=noreply@playhousemedia.co.za
PMG_ADMIN_EMAIL=info@playhousemedia.co.za

# Site
PMG_SITE_URL=https://www.playhousemedia.co.za
