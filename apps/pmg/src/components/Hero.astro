---
// apps/pmg/src/components/Hero.astro
---

<section id="home" class="hero-section">
  <div class="hero-grid">
    <!-- Left Column: Corporate Pitch -->
    <div class="hero-content">
      <div class="eyebrow">
        <span class="eyebrow-line"></span>
        <span>Corporate Holding Company</span>
      </div>

      <h1 class="hero-title">
        <span class="title-line">Where ideas</span>
        <span class="title-line">become <em>empires.</em></span>
      </h1>

      <p class="hero-sub">
        Playhouse Media Group (PMG) powers tendering excellence and web technology solutions. We
        strategically manage flagship service divisions while directly handling corporate graphic
        design and SaaS operations.
      </p>

      <div class="hero-contact-row">
        <a href="tel:+27740491433" class="contact-badge">
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
            ></path>
          </svg>
          074 049 1433
        </a>
        <a href="mailto:info@playhousemedia.co.za" class="contact-badge">
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
            ></path>
            <polyline points="22,6 12,13 2,6"></polyline>
          </svg>
          info@playhousemedia.co.za
        </a>
      </div>

      <div class="hero-actions">
        <a
          href="https://wa.me/27740491433?text=Hi%2C+I+found+Playhouse+Media+Group+and+would+like+to+discuss+a+project."
          class="cta-btn"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="currentColor"
            style="margin-right: 4px; vertical-align: middle;"
          >
            <path
              d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
            ></path>
          </svg>
          Start a Project
        </a>
      </div>
    </div>

    <!-- Right Column: Flagship Division Cards -->
    <div class="hero-divisions">
      <!-- Tender Edge Solutions Card -->
      <a
        href="https://tenderedgesolutions.co.za"
        class="division-card-compact"
        target="_blank"
        rel="noopener noreferrer"
      >
        <div class="card-header-compact">
          <div class="badge-compact">Flagship Venture</div>
          <div class="icon-compact">
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
              <polyline points="14,2 14,8 20,8"></polyline>
              <line x1="16" y1="13" x2="8" y2="13"></line>
              <line x1="16" y1="17" x2="8" y2="17"></line>
            </svg>
          </div>
        </div>
        <h3>Tender Edge Solutions (TES)</h3>
        <p>
          Government bid compilation, CSD profile updates, CIDB gradings, and compliance
          returnables compilation.
        </p>
        <span class="card-action-text">
          Visit Website
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <line x1="7" y1="17" x2="17" y2="7"></line><polyline points="7 7 17 7 17 17"
            ></polyline>
          </svg>
        </span>
      </a>

      <!-- Apex Web Solutions Card -->
      <a
        href="https://apexwebsolutions.co.za"
        class="division-card-compact"
        target="_blank"
        rel="noopener noreferrer"
      >
        <div class="card-header-compact">
          <div class="badge-compact">Flagship Venture</div>
          <div class="icon-compact">
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <rect x="3" y="3" width="18" height="18" rx="2"></rect>
              <path d="M3 9h18M9 21V9"></path>
            </svg>
          </div>
        </div>
        <h3>Apex Web Solutions (AWS)</h3>
        <p>
          Premium custom web design, high-performance software development, domain management, and
          cloud hosting.
        </p>
        <span class="card-action-text">
          Visit Website
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <line x1="7" y1="17" x2="17" y2="7"></line><polyline points="7 7 17 7 17 17"
            ></polyline>
          </svg>
        </span>
      </a>

      <!-- TenderTrack 360 Card -->
      <a
        href="https://tendertrack360.co.za"
        class="division-card-compact"
        target="_blank"
        rel="noopener noreferrer"
      >
        <div class="card-header-compact">
          <div class="badge-compact">SaaS Platform · Beta</div>
          <div class="icon-compact">
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <circle cx="12" cy="12" r="10"></circle>
              <polyline points="12 6 12 12 16 14"></polyline>
            </svg>
          </div>
        </div>
        <h3>TenderTrack 360</h3>
        <p>
          Cloud-based tender management platform. Track, manage, and follow up on tenders —
          free during the beta period.
        </p>
        <span class="card-action-text">
          Try Free Beta
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <line x1="7" y1="17" x2="17" y2="7"></line><polyline points="7 7 17 7 17 17"
            ></polyline>
          </svg>
        </span>
      </a>
    </div>
  </div>
</section>
