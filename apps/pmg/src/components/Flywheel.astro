---
// apps/pmg/src/components/Flywheel.astro
---

<!-- Flywheel Section -->
<section id="why-pmg" class="section scroll-mt">
  <div class="section-header">
    <span class="section-tag">Synergy</span>
    <h2>The PMG Growth Flywheel</h2>
    <p class="section-desc">
      Our business model operates as an integrated ecosystem where each division fuels the next,
      providing a client for life.
    </p>
  </div>

  <div class="flywheel-container">
    <div class="flywheel-steps">
      <div class="flywheel-step">
        <span class="step-num">01</span>
        <div class="step-content">
          <h4>Branding</h4>
          <p>
            They establish their corporate identity with a logo & profile at <strong
              >Playhouse Creative Studio</strong
            >.
          </p>
        </div>
      </div>

      <div class="flywheel-arrow">
        <svg
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"
          ></polyline>
        </svg>
      </div>

      <div class="flywheel-step">
        <span class="step-num">02</span>
        <div class="step-content">
          <h4>Technology</h4>
          <p>
            They deploy an optimized web footprint and email infrastructure using <strong
              >Apex Web Solutions</strong
            >.
          </p>
        </div>
      </div>

      <div class="flywheel-arrow">
        <svg
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"
          ></polyline>
        </svg>
      </div>

      <div class="flywheel-step">
        <span class="step-num">03</span>
        <div class="step-content">
          <h4>Tenders</h4>
          <p>
            They qualify and prepare winning bids for lucrative state contracts with <strong
              >Tender Edge Solutions</strong
            >.
          </p>
        </div>
      </div>

      <div class="flywheel-arrow">
        <svg
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"
          ></polyline>
        </svg>
      </div>

      <div class="flywheel-step">
        <span class="step-num">04</span>
        <div class="step-content">
          <h4>Scale</h4>
          <p>
            They streamline and audit their bids seamlessly on our proprietary <strong>TenderTrack 360</strong> software.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
