<script>
  import { actions } from 'astro:actions';

  const form = document.querySelector('.contact-form') as HTMLFormElement;
  const statusEl = document.querySelector('.form-status') as HTMLDivElement;
  const submitBtn = form?.querySelector('.submit-btn') as HTMLButtonElement;

  if (form && statusEl && submitBtn) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Clear previous status
      statusEl.style.display = 'none';
      statusEl.className = 'form-status';
      statusEl.textContent = '';

      // Disable button & show loading state
      const originalText = submitBtn.textContent;
      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending Inquiry...';

      const formData = new FormData(form);

      try {
        const { data, error } = await actions.submitContactForm(formData);

        if (error) {
          statusEl.style.display = 'block';
          statusEl.classList.add('error');
          statusEl.textContent = error.message || 'An unexpected error occurred. Please try again.';
          return;
        }

        if (data?.success) {
          statusEl.style.display = 'block';
          statusEl.classList.add('success');
          statusEl.textContent =
            'Thank you! Your enquiry has been received successfully. An agent will contact you shortly.';
          form.reset();
        }
      } catch (err) {
        statusEl.style.display = 'block';
        statusEl.classList.add('error');
        statusEl.textContent =
          'A network error occurred. Please check your connection and try again.';
      } finally {
