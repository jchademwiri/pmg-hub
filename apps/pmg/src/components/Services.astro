---
// apps/pmg/src/components/Services.astro
---

<!-- PMG Direct Solutions Section -->
<section id="services" class="section scroll-mt bg-navy-mid-blur">
  <div class="section-header-split">
    <div class="section-header-left">
      <span class="section-tag">Direct Operations</span>
      <h2>PMG Corporate Solutions</h2>
      <p class="section-desc">
        Any business requirements that do not fall directly under AWS or TES are handled directly by
        Playhouse Media Group (PMG), ensuring consistent parent-brand quality.
      </p>
    </div>

    <div class="section-header-right">
      <div class="quick-contact-panel">
        <div>
          <span class="section-tag" style="margin-bottom: 4px;">Connect</span>
          <h3>Talk to Us Today</h3>
          <p class="quick-contact-desc">
            Let’s forge a relationship that will bring your vision to life. Contact our corporate office to get started.
          </p>
        </div>
        <div class="quick-contact-links">
          <a href="tel:+27740491433" class="contact-badge-mini">
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
              ></path>
            </svg>
            <span><strong>Phone Number:</strong> 074 049 1433</span>
          </a>
          <a href="mailto:info@playhousemedia.co.za" class="contact-badge-mini">
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
              ></path>
              <polyline points="22,6 12,13 2,6"></polyline>
            </svg>
            <span><strong>Email Address:</strong> info@playhousemedia.co.za</span>
          </a>
        </div>
      </div>
    </div>
  </div>

  <div class="services-grid">
    <!-- Playhouse Creative Studio -->
    <div class="service-card">
      <div class="service-icon">
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            d="M12 22C17.5228 22 22 17.5228 22 12C22 6.47715 17.5228 2 12 2C6.47715 2 2 6.47715 2 12C2 17.5228 6.47715 22 12 22Z"
          ></path>
          <path d="M12 16a4 4 0 1 0 0-8 4 4 0 0 0 0 8z"></path>
        </svg>
      </div>
      <h3>Playhouse Creative Studio</h3>
      <p class="service-tagline">High-Quality Graphics & Branding</p>
      <p>
        Visually spectacular brand design. We craft premium corporate logos, customized company
        profiles, letterheads, email signatures, digital marketing collateral, and comprehensive
        brand identity packages to differentiate your business.
      </p>
    </div>

    <!-- TenderTrack 360 -->
    <div class="service-card">
      <div class="service-icon">
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"
          ></path>
          <polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline>
          <line x1="12" y1="22.08" x2="12" y2="12"></line>
        </svg>
      </div>
      <h3>TenderTrack 360</h3>
      <p class="service-tagline">SaaS Bid Management Platform</p>
      <p>
        Our standalone software-as-a-service (SaaS) tender monitoring application. Built
        internally by <a
          class="service-link"
          href="https://playhousemedia.co.za"
          target="_blank"
          rel="noopener noreferrer">Playhouse Media Group</a
        >, this platform allows businesses to track, audit, and coordinate active tender bids
        effortlessly under one robust dashboard.
      </p>
    </div>
  </div>
</section>
