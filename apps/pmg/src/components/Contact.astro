---
// apps/pmg/src/components/Contact.astro
---

<!-- Contact Section -->
<section id="contact" class="section scroll-mt">
  <div class="section-header">
    <span class="section-tag">Connect</span>
    <h2>Talk to Us Today</h2>
    <p class="section-desc">
      Let’s forge a relationship that will bring your vision to life. Contact our corporate office
      to get started.
    </p>
  </div>

  <div class="contact-grid">
    <!-- Direct Contact Details -->
    <div class="contact-info-panel">
      <div class="info-group">
        <div class="info-icon">
          <svg
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
            ></path>
          </svg>
        </div>
        <div class="info-details">
          <span>Phone Number</span>
          <a href="tel:+27740491433">074 049 1433</a>
        </div>
      </div>

      <div class="info-group">
        <div class="info-icon">
          <svg
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
            ></path>
            <polyline points="22,6 12,13 2,6"></polyline>
          </svg>
        </div>
        <div class="info-details">
          <span>Email Address</span>
          <a href="mailto:info@playhousemedia.co.za">info@playhousemedia.co.za</a>
        </div>
      </div>

      <div class="info-group">
        <div class="info-icon">
          <svg
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
            <circle cx="12" cy="10" r="3"></circle>
          </svg>
        </div>
        <div class="info-details">
          <span>Corporate Address</span>
          <p>Centurion, Pretoria, 0157</p>
        </div>
      </div>

      <!-- Google Maps Integration Map -->
      <div class="map-placeholder">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3590.1847032977944!2d28.123382475382034!3d-25.86339767728817!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x1e95a18d8fe2bf65%3A0xbe2c68df7f4f8813!2sPlayhouse%20Media%20Group!5e0!3m2!1sen!2sza!4v1698991319924!5m2!1sen!2sza"
          width="100%"
          height="100%"
          style="border:0; filter: grayscale(1) invert(0.9) contrast(1.1);"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Playhouse Media Group Centurion Map"
        >
        </iframe>
      </div>
    </div>

    <!-- sleek Contact Form -->
    <form class="contact-form bottom-contact-form">
      <!-- Honeypot - hidden from real users, catches bots -->
      <div style="position: absolute; left: -9999px;" aria-hidden="true">
        <input type="text" name="_company_url" tabindex="-1" autocomplete="off" />
      </div>

      <!-- Timestamp for time-based bot detection -->
      <input type="hidden" name="_loadedAt" id="loaded-at" value="" />

      <!-- Cloudflare Turnstile -->
      {import.meta.env.TURNSTILE_SITE_KEY && (
        <div class="cf-turnstile" data-sitekey={import.meta.env.TURNSTILE_SITE_KEY} data-action="_turnstile" data-theme="auto"></div>
      )}
      <div class="form-group">
        <label for="name">Full Name</label>
        <input type="text" id="name" name="name" placeholder="Your Name..." required />
      </div>

      <div class="form-group">
        <label for="phone">Phone Number</label>
        <input type="tel" id="phone" name="phone" placeholder="Phone Number..." required />
      </div>

      <div class="form-group">
        <label for="email">Email Address</label>
        <input type="email" id="email" name="email" placeholder="Email..." required />
      </div>

      <div class="form-group">
        <label for="message">Your Message</label>
        <textarea id="message" name="message" placeholder="How can we assist you today?" rows="5" required
        ></textarea>
      </div>

      <div class="form-status bottom-form-status"></div>

      <button type="submit" class="submit-btn bottom-submit-btn">Submit Inquiry</button>
    </form>
  </div>
</section>

<script>
  import { actions } from 'astro:actions';

  const form = document.querySelector('.bottom-contact-form') as HTMLFormElement;
  const statusEl = document.querySelector('.bottom-form-status') as HTMLDivElement;
  const submitBtn = form?.querySelector('.bottom-submit-btn') as HTMLButtonElement;

  // Set timestamp on page load for time-based bot detection
  const loadedAtEl = document.getElementById('loaded-at');
  if (loadedAtEl && !loadedAtEl.value) {
    loadedAtEl.value = new Date().toISOString();
  }

  if (form && statusEl && submitBtn) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Clear previous status
      statusEl.style.display = 'none';
      statusEl.className = 'form-status bottom-form-status';
      statusEl.textContent = '';

      // Disable button & show loading state
      const originalText = submitBtn.textContent;
      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending Inquiry...';

      const formData = new FormData(form);

      try {
        const { data, error } = await actions.submitContactForm(formData);

        if (error) {
          statusEl.style.display = 'block';
          statusEl.classList.add('error');
          statusEl.textContent = error.message || 'An unexpected error occurred. Please try again.';
          return;
        }

        if (data?.success) {
          statusEl.style.display = 'block';
          statusEl.classList.add('success');
          statusEl.textContent = 'Thank you! Your enquiry has been received successfully. An agent will contact you shortly.';
          form.reset();
        }
      } catch (err) {
        statusEl.style.display = 'block';
        statusEl.classList.add('error');
        statusEl.textContent = 'A network error occurred. Please check your connection and try again.';
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = originalText || 'Submit Inquiry';
      }
    });
  }
</script>
