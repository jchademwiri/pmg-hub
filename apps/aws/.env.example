# Database - shared across all apps in the monorepo
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?channel_binding=require&sslmode=require
DATABASE_URL_UNPOOLED=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# Resend – AWS sending identity
# Domain registered in Resend: apexwebsolutions.co.za
# Central config: packages/emails/src/domains.ts → DOMAINS.aws
# resolveBrandEmailConfig('aws', import.meta.env) reads these keys
AWS_RESEND_API_KEY=re_xxxxxxxxxxxx
AWS_FROM_EMAIL=noreply@info.apexwebsolutions.co.za
AWS_ADMIN_EMAIL=info@apexwebsolutions.co.za

# Site URL - used for canonical links and OG tags
AWS_SITE_URL=https://apexwebsolutions.co.za
