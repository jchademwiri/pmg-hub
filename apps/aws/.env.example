# ─────────────────────────────────────────────
# AWS — Apex Web Solutions
# apps/aws/.env.example
# Copy to .env.local and fill in real values.
# Never commit .env.local
#
# DATABASE_URL lives in the root .env.local —
# no need to repeat it here.
# ─────────────────────────────────────────────

# Resend — AWS sending identity
# From domain: apexwebsolutions.co.za (must be verified in Resend)
AWS_RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
AWS_FROM_EMAIL=noreply@apexwebsolutions.co.za
AWS_ADMIN_EMAIL=info@apexwebsolutions.co.za

# Site
AWS_SITE_URL=https://www.apexwebsolutions.co.za
