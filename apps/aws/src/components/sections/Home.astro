---
const features = [
  "Response Design",
  "Modern Tech Stack",
  "SEO Optimized",
  "High Performance",
];
---

<section
  id="home"
  class="relative flex min-h-screen items-center justify-center overflow-hidden pt-16 md:pt-0"
>
  <!-- Dynamic Canvas Background -->
  <div class="bg-background absolute inset-0 -z-10">
    <canvas id="hero-canvas" class="absolute inset-0 h-full w-full"></canvas>
    <!-- Gradients for depth (over canvas) -->
    <div
      class="from-background/90 via-background/50 to-background/20 pointer-events-none absolute inset-0 z-10 bg-linear-to-r"
    >
    </div>
    <div
      class="from-background/20 to-background/90 pointer-events-none absolute inset-0 z-10 bg-linear-to-b via-transparent"
    >
    </div>
  </div>

  <div class="relative z-20 container mx-auto px-4">
    <div class="grid gap-12 lg:grid-cols-2 lg:gap-8">
      <!-- Content Column -->
      <div class="flex flex-col justify-center space-y-8">
        <div class="animate-fade-in-up space-y-4">
          <div
            class="border-primary/20 bg-primary/10 text-primary inline-flex items-center rounded-full border px-3 py-1 text-sm font-medium backdrop-blur-sm"
          >
            <span class="bg-primary mr-2 flex h-2 w-2 rounded-full"></span>
            Elevate Your Digital Presence
          </div>

          <h1
            class="text-4xl font-extrabold tracking-tight sm:text-5xl md:text-6xl lg:text-7xl"
          >
            Professional <br />
            <span
              class="from-primary to-secondary bg-linear-to-r bg-clip-text text-transparent"
            >
              Web Solutions
            </span>
          </h1>

          <p
            class="text-muted-foreground max-w-xl text-lg leading-relaxed md:text-xl"
          >
            We create stunning, responsive websites that drive results.
            Strategic digital architecture tailored for your business growth.
            Experience the difference of senior-level engineering.
          </p>
        </div>

        <!-- Action Buttons -->
        <div
          class="animate-fade-in-up flex flex-col gap-4 delay-100 sm:flex-row"
        >
          <a
            href="#contact"
            class="bg-primary text-primary-foreground shadow-primary/20 hover:shadow-primary/40 focus-visible:ring-primary inline-flex h-12 items-center justify-center rounded-lg px-8 text-sm font-medium shadow-lg transition-all hover:scale-105 focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:outline-none"
          >
            Start a Conversation
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="ml-2 h-4 w-4"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </a>
          <a
            href="#pricing"
            class="border-input bg-background/50 hover:bg-accent hover:text-accent-foreground focus-visible:ring-ring inline-flex h-12 items-center justify-center rounded-lg border px-8 text-sm font-medium shadow-sm backdrop-blur-sm transition-all hover:scale-105 focus-visible:ring-2 focus-visible:outline-none"
          >
            Request a Quote
          </a>
        </div>

        <!-- Trust Indicators / Features -->
        <div class="animate-fade-in-up pt-8 delay-200">
          <p
            class="text-muted-foreground mb-4 text-sm font-medium tracking-wider uppercase"
          >
            Trusted for
          </p>
          <div class="flex flex-wrap gap-x-8 gap-y-4">
            {
              features.map((feature) => (
                <div class="text-foreground/80 flex items-center gap-2 text-sm font-medium">
                  <svg
                    class="text-secondary h-5 w-5"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M5 13l4 4L19 7"
                    />
                  </svg>
                  {feature}
                </div>
              ))
            }
          </div>
        </div>
      </div>

      <!-- Visual Column -->
      <div class="hidden lg:block">
        <!-- Canvas area specifically visible here without heavy overlay -->
      </div>
    </div>
  </div>
</section>

<script>
  class ParticleNetwork {
    canvas: HTMLCanvasElement;
    ctx: CanvasRenderingContext2D;
    width: number;
    height: number;
    particles: Particle[];
    options: any;

    constructor(canvas: HTMLCanvasElement) {
      this.canvas = canvas;
      const context = canvas.getContext("2d");
      if (!context) throw new Error("Could not get canvas context");
      this.ctx = context;
      this.width = canvas.offsetWidth;
      this.height = canvas.offsetHeight;
      this.particles = [];

      this.options = {
        particleColor: "rgba(59, 130, 246, 0.7)", // Blue-500
        lineColor: "rgba(59, 130, 246, 0.2)",
        packetColor: "rgba(168, 85, 247, 0.8)", // Purple-500 (Secondary)
        particleAmount: this.calculateParticleAmount(),
        defaultSpeed: 0.5,
        variantSpeed: 1,
        linkRadius: 150,
      };

      this.init();
      this.animate();
      window.addEventListener("resize", () => this.resize());
    }

    calculateParticleAmount() {
      return Math.floor((window.innerWidth * window.innerHeight) / 15000);
    }

    init() {
      this.resize();
      this.particles = [];
      for (let i = 0; i < this.options.particleAmount; i++) {
        this.particles.push(new Particle(this.width, this.height));
      }
    }

    resize() {
      this.width = this.canvas.parentElement?.offsetWidth || window.innerWidth;
      this.height =
        this.canvas.parentElement?.offsetHeight || window.innerHeight;
      this.canvas.width = this.width;
      this.canvas.height = this.height;

      // Update particle count on resize for density consistency
      const newAmount = this.calculateParticleAmount();
      if (this.particles.length < newAmount) {
        for (let i = this.particles.length; i < newAmount; i++) {
          this.particles.push(new Particle(this.width, this.height));
        }
      } else if (this.particles.length > newAmount) {
        this.particles.splice(newAmount);
      }
    }

    animate() {
      this.ctx.clearRect(0, 0, this.width, this.height);

      // Update and draw particles
      this.particles.forEach((particle) => {
        particle.update(this.width, this.height);
        particle.draw(this.ctx, this.options.particleColor);
      });

      // Draw connections and packets
      this.drawConnections();

      requestAnimationFrame(() => this.animate());
    }

    drawConnections() {
      const time = Date.now() / 1000; // time in seconds for packet flow

      for (let i = 0; i < this.particles.length; i++) {
        for (let j = i + 1; j < this.particles.length; j++) {
          const p1 = this.particles[i];
          const p2 = this.particles[j];
          const distance = Math.sqrt(
            Math.pow(p1.x - p2.x, 2) + Math.pow(p1.y - p2.y, 2),
          );

          if (distance < this.options.linkRadius) {
            const opacity = 1 - distance / this.options.linkRadius;

            // Draw Line
            this.ctx.beginPath();
            this.ctx.strokeStyle = `rgba(59, 130, 246, ${opacity * 0.3})`; // Blue tint
            this.ctx.lineWidth = 1;
            this.ctx.moveTo(p1.x, p1.y);
            this.ctx.lineTo(p2.x, p2.y);
            this.ctx.stroke();

            // Draw Packet (Data Flow) - visual candy
            // We only carry packets on stronger connections to avoid noise
            if (opacity > 0.3) {
              const speed = 2; // Packets per second approx
              // Create a "flow" position 0..1 based on time + unique offset for pair
              // Use prime number scale to avoid sync
              const offset = (i * j) % 1000;
              const t = (time * speed + offset) % 2;

              // t goes 0..2. if t > 1, no packet (gap). if t < 1, draw packet
              if (t < 1) {
                const packetX = p1.x + (p2.x - p1.x) * t;
                const packetY = p1.y + (p2.y - p1.y) * t;

                this.ctx.beginPath();
                this.ctx.fillStyle = `rgba(232, 121, 249, ${opacity})`; // Fuchsia glow
                this.ctx.arc(packetX, packetY, 2, 0, Math.PI * 2);
                this.ctx.fill();
              }
            }
          }
        }
      }
    }
  }

  class Particle {
    x: number;
    y: number;
    vx: number;
    vy: number;
    size: number;

    constructor(w: number, h: number) {
      this.x = Math.random() * w;
      this.y = Math.random() * h;
      this.vx = (Math.random() - 0.5) * 0.5;
      this.vy = (Math.random() - 0.5) * 0.5;
      this.size = Math.random() * 2 + 1;
    }

    update(w: number, h: number) {
      this.x += this.vx;
      this.y += this.vy;

      // Bounce
      if (this.x < 0 || this.x > w) this.vx *= -1;
      if (this.y < 0 || this.y > h) this.vy *= -1;
    }

    draw(ctx: CanvasRenderingContext2D, color: string) {
      ctx.beginPath();
      ctx.fillStyle = color;
      ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
      ctx.fill();
    }
  }

  // Init
  const canvas = document.getElementById("hero-canvas") as HTMLCanvasElement;
  if (canvas) {
    new ParticleNetwork(canvas);
  }
</script>

<style>
  .animate-fade-in-up {
    animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    opacity: 0;
    transform: translateY(20px);
  }

  .delay-100 {
    animation-delay: 0.1s;
  }

  .delay-200 {
    animation-delay: 0.2s;
  }

  @keyframes fadeInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
