---
import ContactForm from "../forms/ContactForm.astro";
---

<section id="contact" class="bg-background relative overflow-hidden py-24">
  <!-- Decorative Elements -->
  <div
    class="bg-primary/5 absolute top-0 right-0 -z-10 h-1/3 w-1/3 translate-x-1/2 -translate-y-1/2 rounded-full blur-3xl"
  >
  </div>
  <div
    class="bg-primary/5 absolute bottom-0 left-0 -z-10 h-1/4 w-1/4 -translate-x-1/2 translate-y-1/2 rounded-full blur-3xl"
  >
  </div>

  <div class="container mx-auto px-4">
    <div class="grid items-start gap-12 lg:grid-cols-2 lg:gap-24">
      <!-- Contact Info -->
      <div class="relative z-10">
        <h2 class="mb-6 text-3xl font-bold md:text-5xl">
          Let's Start a <br />
          <span class="text-primary">Conversation</span>
        </h2>
        <p class="text-muted-foreground mb-12 max-w-md text-lg leading-relaxed">
          Ready to transform your digital presence? We're here to help you build
          scalable and impactful web solutions.
        </p>

        <div class="space-y-8">
          <div class="flex items-start gap-4">
            <div
              class="bg-primary/10 flex h-12 w-12 shrink-0 items-center justify-center rounded-lg"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="text-primary h-6 w-6"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                ></path>
              </svg>
            </div>
            <div>
              <h3 class="mb-1 text-lg font-bold">Email Us</h3>
              <a
                href="mailto:info@apexwebsolutions.co.za"
                class="text-muted-foreground hover:text-primary transition-colors"
              >
                info@apexwebsolutions.co.za
              </a>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div
              class="bg-primary/10 flex h-12 w-12 shrink-0 items-center justify-center rounded-lg"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="text-primary h-6 w-6"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                ></path>
              </svg>
            </div>
            <div>
              <h3 class="mb-1 text-lg font-bold">Call/WhatsApp</h3>
              <a
                href="tel:+27740491433"
                class="text-muted-foreground hover:text-primary transition-colors"
              >
                +27 74 049 1433
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Contact Form -->
      <div
        class="bg-muted/30 border-border/50 relative z-10 rounded-2xl border p-8 shadow-sm backdrop-blur-sm"
      >
        <ContactForm />
      </div>
    </div>
  </div>
</section>
