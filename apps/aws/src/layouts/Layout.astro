---
// style import
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import "@/styles/starwind.css";
import GoogleAnalytics from "@/components/GoogleAnalytics.astro";
import HeadSEO from "@/seo/HeadSEO.astro";
import Schema from "@/seo/Schema.astro";
import type {
  Graph,
  ProfessionalService,
  BreadcrumbList,
  ListItem,
} from "schema-dts";

const {
  title,
  description = "Premium web design and development for South African SMEs. Affordable, high-performance websites starting from R299/month.",
} = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const businessSchema: ProfessionalService = {
  "@type": "ProfessionalService",
  name: "Apex Web Solutions",
  url: "https://apexwebsolutions.co.za",
  image: "https://apexwebsolutions.co.za/og-image.jpg",
  description:
    "Premium web design and development for South African SMEs. Affordable, high-performance websites.",
  address: {
    "@type": "PostalAddress",
    addressCountry: "ZA",
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: -30.5595,
    longitude: 22.9375,
  },
  areaServed: {
    "@type": "Country",
    name: "South Africa",
  },
  priceRange: "R150 - R50000",
  telephone: "+27740491433",
  email: "info@apexwebsolutions.co.za",
};

const breadcrumbSchema: BreadcrumbList = {
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: "https://apexwebsolutions.co.za",
    } as ListItem,
    ...(Astro.url.pathname !== "/"
      ? [
          {
            "@type": "ListItem",
            position: 2,
            name: title,
            item: new URL(Astro.url.pathname, Astro.site).href,
          } as ListItem,
        ]
      : []),
  ],
};

const graphSchema: Graph = {
  "@context": "https://schema.org",
  "@graph": [businessSchema, breadcrumbSchema],
};
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <GoogleAnalytics />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <HeadSEO
      title={title}
      description={description}
      canonicalUrl={canonicalURL}
    />

    <script is:inline>
      (function () {
        const theme = localStorage.getItem("theme");
        const systemDark = window.matchMedia(
          "(prefers-color-scheme: dark)",
        ).matches;

        // If user chose dark OR hasn't chosen but system is dark
        if (theme === "dark" || (!theme && systemDark)) {
          document.documentElement.classList.add("dark");
        } else {
          document.documentElement.classList.remove("dark");
        }
      })();
    </script>

    <!-- Structured Data -->
    <Schema item={graphSchema} />
  </head>

  <body class="bg-muted antialiased">
    <Header />
    <slot />
    <Footer />
  </body>
</html>
