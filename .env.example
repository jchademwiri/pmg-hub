# ═══════════════════════════════════════════════════════
# PMG Hub - Root Shared Environment Variables
# .env.example  ·  copy to .env.local, never commit it
#
# This file contains variables shared across ALL apps.
# App-specific variables live in apps/[site]/.env.local
# ═══════════════════════════════════════════════════════

# ── Database (shared Neon instance) ──────────────────
# Used by: @pmg/db, apps/admin, apps/tes, apps/aws, apps/pmg
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?channel_binding=require&sslmode=require
DATABASE_URL_UNPOOLED=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require
