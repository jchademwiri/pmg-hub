# ═══════════════════════════════════════════════════════
# PMG Hub - Root Shared Environment Variables
# .env.example  ·  copy to .env.local, never commit it
#
# This file contains variables shared across ALL apps.
# App-specific variables live in apps/[site]/.env.local
# ═══════════════════════════════════════════════════════

# ── Database (shared Neon instance) ──────────────────
# Used by: @pmg/db, apps/admin, apps/tes, apps/aws, apps/pmg
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?channel_binding=require&sslmode=require
DATABASE_URL_UNPOOLED=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# ── Resend API keys (one per brand / Resend account) ─
# Source of truth for which key belongs to which brand:
#   packages/emails/src/domains.ts  →  RESEND_API_KEY_ENV & DOMAINS
#
# To rotate or change a domain:
#   1. Update the verified domain in the Resend dashboard for that account.
#   2. Update DOMAINS.<brand> in packages/emails/src/domains.ts.
#   3. Replace the value below in every app's .env.local AND in Vercel.
#
# PMG – Playhouse Media Group  (domain: playhousemedia.co.za)
PMG_RESEND_API_KEY=re_xxxxxxxxxxxx
#
# TES – Tender Edge Solutions  (domain: tenderedgesolutions.co.za)
TES_RESEND_API_KEY=re_xxxxxxxxxxxx
#
# AWS – Apex Web Solutions     (domain: apexwebsolutions.co.za)
AWS_RESEND_API_KEY=re_xxxxxxxxxxxx

# Cloudflare Turnstile (bot protection)
TURNSTILE_SITE_KEY=xxxxxxxxxxxx
TURNSTILE_SECRET_KEY=xxxxxxxxxxxx

# Cloudflare R2 (database exports and backups)
CLOUDFLARE_R2_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_R2_ACCESS_KEY_ID=your-r2-access-key-id
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
CLOUDFLARE_R2_BUCKET=pmg-hub-backups
CLOUDFLARE_R2_BACKUP_PREFIX=database-backups
CLOUDFLARE_R2_BACKUP_RETENTION_DAYS=90
