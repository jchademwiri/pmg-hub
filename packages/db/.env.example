# Create a .env file inside packages/db/ (and your app folders) with your Neon credentials:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require
# DATABASE_URL_UNPOOLED=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

DATABASE_URL="postgresql://placeholder_user:placeholder_password@placeholder_host/neondb?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://placeholder_user:placeholder_password@placeholder_host/neondb?sslmode=require"
