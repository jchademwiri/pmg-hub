# Required: PostgreSQL connection string (pooled)
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgres://user:password@localhost:5432/pmg_db

# Required: PostgreSQL connection string (unpooled, for migrations)
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL_UNPOOLED=postgres://user:password@localhost:5432/pmg_db
