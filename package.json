{
  "name": "pmg-hub",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev db:studio",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "db:generate": "bun --filter @pmg/db db:generate",
    "db:migrate": "bun --filter @pmg/db db:migrate",
    "db:push": "bun --filter @pmg/db db:push",
    "db:reset": "bun --filter @pmg/db db:reset",
    "db:seed": "bun --filter @pmg/db db:seed",
    "db:studio": "bun --filter @pmg/db db:studio"
  },
  "catalog": {
    "astro": "^6.0.8",
    "tailwindcss": "4.2.2",
    "@tailwindcss/vite": "4.2.2",
    "@tailwindcss/node": "4.2.2",
    "@tailwindcss/oxide": "4.2.2",
    "typescript": "5.9.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.8.20",
    "typescript": "catalog:",
    "tailwindcss": "catalog:",
    "@tailwindcss/vite": "catalog:"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "bun@1.3.5",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "vercel": "^50.37.0",
    "zod": "catalog:"
  },
  "overrides": {
    "tailwindcss": "4.2.2",
    "@tailwindcss/vite": "4.2.2",
    "@tailwindcss/node": "4.2.2",
    "@tailwindcss/oxide": "4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3"
  },
  "trustedDependencies": [
    "@tailwindcss/oxide"
  ]
}
